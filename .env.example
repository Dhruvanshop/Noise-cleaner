# Production Environment Variables
# Copy to .env and fill in real values

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info

# ── Application ──────────────────────────────────────────────────
# Set to 'production' to enable production optimizations
ENVIRONMENT=production

# Maximum file size in MB (recommended: 100)
MAX_FILE_SIZE_MB=100

# Maximum concurrent processing jobs
NC_WORKERS=4

# Temp directory for processing (use persistent storage in production)
NC_TEMP_DIR=/var/lib/noise_cleaner/temp

# Job TTL in seconds (default: 2 hours)
NC_JOB_TTL=7200

# Cleanup interval in seconds (default: 30 minutes)
NC_CLEANUP_INTERVAL=1800

# ── Security ─────────────────────────────────────────────────────
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limiting: requests per minute per IP
RATE_LIMIT_PER_MINUTE=10

# Secret key for sessions (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_use_openssl_rand

# ── Features ─────────────────────────────────────────────────────
# Set to 'false' to disable AI denoising (recommended for commercial use due to CC-BY-NC license)
ENABLE_AI_DENOISE=false

# Set to 'true' to enable pro features (requires user accounts)
ENABLE_PRO_FEATURES=false

# ── Analytics ────────────────────────────────────────────────────
# Google Analytics tracking ID (optional)
GA_TRACKING_ID=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ── Payment (if using pro features) ──────────────────────────────
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Database (if using pro features) ─────────────────────────────
DATABASE_URL=postgresql://user:password@localhost/noise_cleaner

# ── Storage (for production) ─────────────────────────────────────
# Use S3-compatible storage for processed files
# Options: 's3', 'spaces', 'local' (default: local)
STORAGE_BACKEND=local
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_ENDPOINT_URL=  # For DigitalOcean Spaces, use: https://nyc3.digitaloceanspaces.com

# ── Email (for user accounts) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com
